# ─────────────────────────────────────────────
# AEGIS Backend — 환경변수 예시
# 이 파일을 복사해서 .env로 저장 후 값을 채우세요.
# .env는 절대 git에 커밋하지 마세요.
# ─────────────────────────────────────────────

# MongoDB 계정 (기본값 root/example 절대 사용 금지)
MONGO_USER=aegis_admin
MONGO_PASSWORD=여기에_강력한_비밀번호_입력
MONGO_DB=forensic_db

# 외부에 노출할 포트 (NAS 방화벽 설정과 일치시킬 것)
APP_PORT=8080
MONGO_PORT=27017    # 외부 노출이 필요 없으면 이 줄 삭제

# DELETE /logs/all 엔드포인트 보호용 관리자 토큰
# openssl rand -hex 32 로 생성 권장
ADMIN_TOKEN=여기에_랜덤_토큰_입력

# MongoDB 필드 레벨 암호화 키 (32바이트 Base64)
# openssl rand -base64 32 로 생성 — 절대 바꾸지 말 것 (바꾸면 기존 DB 데이터 복호화 불가)
AEGIS_FIELD_ENC_KEY=여기에_base64_32바이트_키_입력
